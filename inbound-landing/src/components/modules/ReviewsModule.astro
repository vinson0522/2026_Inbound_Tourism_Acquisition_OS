---
import { asRecordArray, pickHeading } from '../../lib/content';

interface Props {
  content: Record<string, unknown>;
}

const { content } = Astro.props;
const heading = pickHeading(content, 'Traveler Reviews');
const items = asRecordArray(content.items ?? content.reviews);
---

<section class="lp-section">
  <h2>{heading}</h2>
  {items.length > 0 ? (
    <div class="lp-grid lp-grid--2">
      {items.map((item) => {
        const quote = String(item.quote ?? item.text ?? '');
        const author = String(item.author ?? item.name ?? 'Traveler');
        const country = item.country ? String(item.country) : '';
        const rating = Number(item.rating ?? 5);
        const stars = '★'.repeat(Math.min(5, Math.max(0, rating)));
        return (
          <blockquote class="lp-card">
            <p>"{quote}"</p>
            <footer>
              <span class="lp-review-stars">{stars}</span>
              <br />
              <cite>
                {author}
                {country ? ` · ${country}` : ''}
              </cite>
            </footer>
          </blockquote>
        );
      })}
    </div>
  ) : (
    <p>Reviews coming soon.</p>
  )}
</section>
