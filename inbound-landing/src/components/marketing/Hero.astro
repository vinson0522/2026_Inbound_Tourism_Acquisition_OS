---
import type { Dictionary } from '../../i18n/ui';

interface Props {
  hero: Dictionary['hero'];
  bookDemoHref: string;
  loginHref: string;
}

const { hero, bookDemoHref, loginHref } = Astro.props;
---

<section class="mk-hero" aria-labelledby="hero-title">
  <div class="mk-hero__inner">
    <p class="mk-hero__sub-zh">{hero.subZh}</p>
    <h1 id="hero-title">{hero.title}</h1>
    <p class="mk-hero__lead">{hero.lead}</p>
    <div class="mk-hero__actions">
      <a class="lp-btn lp-btn--primary" href={bookDemoHref}>{hero.bookDemo}</a>
      <a class="lp-btn lp-btn--outline" href={loginHref}>{hero.login}</a>
    </div>
    <p class="mk-hero__compliance">{hero.compliance}</p>
  </div>
</section>
