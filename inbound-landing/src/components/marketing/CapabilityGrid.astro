---
import type { Dictionary } from '../../i18n/ui';

interface Props {
  capabilities: Dictionary['capabilities'];
}

const { capabilities } = Astro.props;
---

<section id="capabilities" class="mk-section" aria-labelledby="capabilities-title">
  <div class="mk-section__inner">
    <h2 id="capabilities-title" class="mk-section__title">{capabilities.title}</h2>
    <div class="mk-cap-grid">
      {
        capabilities.cards.map((card) => (
          <article class="mk-cap-card">
            <div class="mk-cap-card__head">
              <span class="mk-cap-card__icon" aria-hidden="true">{card.icon}</span>
              <h3>{card.title}</h3>
            </div>
            <ul>
              {card.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
