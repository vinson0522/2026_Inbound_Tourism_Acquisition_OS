---
import type { Dictionary } from '../../i18n/ui';

interface Props {
  cta: Dictionary['cta'];
  bookDemoHref: string;
  loginHref: string;
}

const { cta, bookDemoHref, loginHref } = Astro.props;
---

<section id="contact-cta" class="mk-cta-band" aria-labelledby="cta-title">
  <div class="mk-section__inner">
    <h2 id="cta-title">{cta.title}</h2>
    <p>{cta.body}</p>
    <div class="mk-cta-band__actions">
      <a class="lp-btn lp-btn--accent" href={bookDemoHref}>{cta.bookDemo}</a>
      <a class="lp-btn lp-btn--outline-white" href={loginHref}>{cta.login}</a>
    </div>
  </div>
</section>
