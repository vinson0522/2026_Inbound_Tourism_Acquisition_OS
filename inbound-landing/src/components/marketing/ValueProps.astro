---
import type { Dictionary } from '../../i18n/ui';

interface Props {
  value: Dictionary['value'];
}

const { value } = Astro.props;
---

<section id="value" class="mk-section lp-section--alt" aria-labelledby="value-title">
  <div class="mk-section__inner">
    <h2 id="value-title" class="mk-section__title">{value.title}</h2>
    <div class="mk-value-grid">
      {
        value.cards.map((card) => (
          <article class="mk-value-card">
            <div class="mk-value-card__icon" aria-hidden="true">{card.icon}</div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
