---
import type { Dictionary } from '../../i18n/ui';

interface Props {
  workflow: Dictionary['workflow'];
}

const { workflow } = Astro.props;
const steps = workflow.steps;
---

<section class="mk-workflow" aria-label="How TourGEO works">
  <p class="mk-workflow__inner">
    {
      steps.map((step, i) => (
        <>
          {i === 0 || i === steps.length - 1 ? <strong>{step}</strong> : <span>{step}</span>}
          {i < steps.length - 1 && ' → '}
        </>
      ))
    }
  </p>
</section>
