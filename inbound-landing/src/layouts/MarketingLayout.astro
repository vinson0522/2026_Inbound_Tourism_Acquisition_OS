---
import '../styles/marketing.css';
import { getDict, localizePath, switchLangPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  canonicalUrl?: string;
  adminUrl: string;
}

const { lang, title, description, canonicalUrl, adminUrl } = Astro.props;
const dict = getDict(lang);
const year = new Date().getFullYear();
const pathname = Astro.url.pathname;

const homeHref = localizePath(lang, '/');
const featuresHref = `${homeHref}#capabilities`;
const pricingHref = localizePath(lang, '/pricing');
const contactHref = localizePath(lang, '/contact');

const otherLang: Lang = lang === 'en' ? 'zh' : 'en';
const otherLangHref = switchLangPath(lang, otherLang, pathname);
const otherLangLabel = otherLang === 'zh' ? '中文' : 'EN';
---

<!doctype html>
<html lang={dict.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="alternate" hreflang="en" href={switchLangPath(lang, 'en', pathname)} />
    <link rel="alternate" hreflang="zh" href={switchLangPath(lang, 'zh', pathname)} />
  </head>
  <body>
    <div class="mk-page">
      <header class="mk-header">
        <a class="mk-header__logo" href={homeHref}>TourGEO</a>
        <nav class="mk-header__nav" aria-label="Primary">
          <a href={featuresHref}>{dict.nav.features}</a>
          <a href={pricingHref}>{dict.nav.pricing}</a>
          <a href={contactHref}>{dict.nav.contact}</a>
        </nav>
        <div class="mk-header__actions">
          <a class="mk-lang-toggle" href={otherLangHref} hreflang={otherLang} rel="alternate">{otherLangLabel}</a>
          <a class="lp-btn lp-btn--outline" href={adminUrl}>{dict.nav.login}</a>
        </div>
      </header>
      <main class="mk-main">
        <slot />
      </main>
      <footer class="mk-footer">
        <p>© {year} {dict.footer.rights}</p>
        <div class="mk-footer__links">
          <a href={pricingHref}>{dict.nav.pricing}</a>
          <span aria-hidden="true">·</span>
          <a href={contactHref}>{dict.nav.contact}</a>
          <span aria-hidden="true">·</span>
          <a href={localizePath(lang, '/privacy')}>{dict.footer.privacy}</a>
          <span aria-hidden="true">·</span>
          <a href={localizePath(lang, '/terms')}>{dict.footer.terms}</a>
          <span aria-hidden="true">·</span>
          <a href={otherLangHref}>{otherLangLabel}</a>
        </div>
        <p class="mk-footer__disclaimer">{dict.footer.disclaimer}</p>
        <p>{dict.footer.poweredBy}</p>
      </footer>
    </div>
  </body>
</html>
