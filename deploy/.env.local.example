# 复制为 deploy/.env 后使用（已在 .gitignore）
# D 盘本地 Docker 开发 — 见 LOCAL_DOCKER.md

# 所有容器数据落盘目录（bind mount，可整目录删除）
INBOUND_DOCKER_DATA=D:/Dev/SDKs/Docker/inbound-growth

# ai-api
AI_SERVICE_INTERNAL_TOKEN=dev_internal_token_change_me
DIAGNOSE_WORKER_ENABLED=true
CORE_CALLBACK_BASE_URL=http://host.docker.internal:8080
DIAGNOSE_MOCK_LLM=false

# LLM（勿提交真实值）
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
PERPLEXITY_API_KEY=
