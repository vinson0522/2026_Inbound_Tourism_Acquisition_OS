# Inbound Growth Agent — 本地开发环境变量示例
# 复制为 .env 后按需修改（当前 docker-compose.yml 已内联 dev 默认值，此文件供应用 scaffold 后使用）

# PostgreSQL
POSTGRES_DB=inbound_growth
POSTGRES_USER=inbound
POSTGRES_PASSWORD=change_me_in_prod

# RabbitMQ
RABBITMQ_DEFAULT_USER=inbound
RABBITMQ_DEFAULT_PASS=change_me_in_prod

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_prod

# Langfuse
NEXTAUTH_SECRET=change_me_in_prod
SALT=change_me_in_prod
NEXTAUTH_URL=http://localhost:3000

# Java core-api（scaffold 后）
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/inbound_growth
AI_SERVICE_BASE_URL=http://ai-api:8090
AI_SERVICE_INTERNAL_TOKEN=change_me_in_prod

# Python ai-api（scaffold 后）
DATABASE_URL=postgresql+asyncpg://inbound:change_me_in_prod@postgres:5432/inbound_growth
RABBITMQ_URL=amqp://inbound:change_me_in_prod@rabbitmq:5672/
LANGFUSE_HOST=http://langfuse:3000

# LLM Keys（勿提交真实值）
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
