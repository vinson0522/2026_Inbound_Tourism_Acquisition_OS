# Copy to .env.development for `pnpm dev`
PLASMO_PUBLIC_API_BASE=http://localhost:8080
# Must match inbound.probe.allowed-node-keys in Java application-dev.yml
PLASMO_PUBLIC_NODE_KEY=demo-probe-1
PLASMO_PUBLIC_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e
# Set true to skip Perplexity DOM/hook and submit mock capture (poll→result E2E)
PLASMO_PUBLIC_PROBE_MOCK=false
