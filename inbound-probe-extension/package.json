{
  "name": "inbound-probe-extension",
  "displayName": "TourGEO Probe",
  "version": "0.1.0",
  "description": "Chrome MV3 GEO probe — poll tasks and capture Perplexity / ChatGPT citations",
  "author": "TourGEO",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test:adapter": "node scripts/test-adapter.mjs",
    "test:perplexity-hook": "node scripts/test-perplexity-hook.mjs"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.287",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "prettier": "3.4.2",
    "typescript": "5.7.2"
  },
  "manifest": {
    "host_permissions": [
      "https://www.perplexity.ai/*",
      "https://chatgpt.com/*",
      "http://localhost:8080/*",
      "http://127.0.0.1:8080/*"
    ],
    "permissions": ["alarms", "storage", "tabs", "scripting"]
  }
}
