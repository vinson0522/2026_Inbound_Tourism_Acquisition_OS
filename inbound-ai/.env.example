# Inbound AI — Phase 1 (EPIC-10 scaffold)
# Copy to .env and fill secrets. Never commit .env.

AI_SERVICE_INTERNAL_TOKEN=dev_internal_token_change_me

# Optional Phase 1 — at least one for /ai/llm/complete smoke
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=
# PERPLEXITY_API_KEY=pplx-...

# Optional — Phase 1 /health reports db: skipped if unset
# DATABASE_URL=postgresql+asyncpg://inbound:***@127.0.0.1:15432/inbound_growth

# Optional Langfuse observability
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=http://127.0.0.1:3100

# EPIC-2 — RabbitMQ diagnose worker (optional; enable with DIAGNOSE_WORKER_ENABLED=true)
# RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
# CORE_CALLBACK_BASE_URL=http://localhost:8080
# DIAGNOSE_WORKER_ENABLED=false
# DIAGNOSE_MOCK_LLM=false

# EPIC-10 Phase 2 — embed worker + RAG
# EMBED_WORKER_ENABLED=true
# EMBED_MOCK=true
# EMBEDDING_MODEL=openai/text-embedding-3-small
