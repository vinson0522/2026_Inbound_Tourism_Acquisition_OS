# Inbound AI — Phase 1 (EPIC-10 scaffold)
# Copy to .env and fill secrets. Never commit .env.

AI_SERVICE_INTERNAL_TOKEN=dev_internal_token_change_me

# Optional Phase 1 — at least one for /ai/llm/complete smoke
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=
# PERPLEXITY_API_KEY=pplx-...

# Optional — Phase 1 /health reports db: skipped if unset
DATABASE_URL=postgresql+asyncpg://inbound:inbound_dev_pass@127.0.0.1:5432/inbound_growth

# Optional Langfuse observability
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=http://127.0.0.1:3100

# EPIC-2 — RabbitMQ diagnose worker (optional; enable with DIAGNOSE_WORKER_ENABLED=true)
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
CORE_CALLBACK_BASE_URL=http://localhost:8080
DIAGNOSE_WORKER_ENABLED=true
DIAGNOSE_MOCK_LLM=true

# EPIC-10 Phase 2.2 — Docling + MinIO (file fetch for embed worker)
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin_dev
# MINIO_BUCKET=inbound-growth

# EPIC-3 M1 — keyword generation (FR-201)
# KEYWORDS_MOCK_LLM=true
# KEYWORDS_MODEL=openai/gpt-4o-mini
# KEYWORDS_TEMPLATE_NAME=keyword_generate_v1

# EPIC-3 M2 — keyword opportunity scoring (FR-203 / ADR-19)
# KEYWORD_SCORE_MOCK_LLM=true
# KEYWORD_SCORE_MODEL=openai/gpt-4o-mini
# KEYWORD_SCORE_TEMPLATE_NAME=keyword_score_v1

# EPIC-4 M1 — content script generation (FR-301/302)
# CONTENT_MOCK_LLM=true
# CONTENT_MODEL=openai/gpt-4o-mini
# CONTENT_TEMPLATE_NAME=content_script_v1
# EMBED_WORKER_ENABLED=true
# EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENAI_API_KEY=sk-...   # required when EMBED_MOCK=false
EMBED_MOCK=true
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_MOCK=true
# RAG_VECTOR_TOP_K=20
# RAG_RERANK_TOP_K=3

# EPIC-6 M1 — landing page generation (FR-502~505)
# LANDING_MOCK_LLM=true
# LANDING_MODEL=openai/gpt-4o-mini
# LANDING_TEMPLATE_NAME=landing_generate_v1

# EPIC-5 M1 — viral video breakdown (FR-402/403)
# BREAKDOWN_MOCK_LLM=true
# BREAKDOWN_MODEL=openai/gpt-4o-mini
# BREAKDOWN_TEMPLATE_NAME=video_breakdown_v1
# BREAKDOWN_WORKER_ENABLED=false
# CORE_CALLBACK_BASE_URL=http://localhost:8080

# EPIC-7 M3 — lead follow-up suggestion (FR-603)
# FOLLOWUP_MOCK_LLM=true
# FOLLOWUP_MODEL=openai/gpt-4o-mini
# FOLLOWUP_TEMPLATE_NAME=lead_followup_v1
